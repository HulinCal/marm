<?xml version="1.0"?>
<robot xmlns:xacro="http://www.ros.org/wiki/xacro" name="marm">
    <xacro:arg name="initial_positions_file" default="initial_positions.yaml" />

    <!-- Import marm urdf file -->
    <xacro:include filename="$(find marm)/urdf/arm.urdf" />

    <!-- Import control_xacro -->
    <xacro:include filename="marm.ros2_control.xacro" />


    <xacro:marm_ros2_control name="FakeSystem" initial_positions_file="$(arg initial_positions_file)"/>

</robot>
